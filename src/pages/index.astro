---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import AboutSection from '../components/AboutSection.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';

const alternates = [
  { hrefLang: 'pl', href: 'https://lucyepoxy.com/' },
  { hrefLang: 'en', href: 'https://lucyepoxy.com/en/' },
  { hrefLang: 'de', href: 'https://lucyepoxy.com/de/' },
];
---

<MainLayout
  title="Lucy Epoxy Studio | Stoły i blaty z żywicy epoksydowej"
  description="Ekskluzywne realizacje epoxy w Polsce: stoły river table, blaty, elementy dekoracyjne. Projekt, wykonanie i montaż."
  lang="pl"
  pathname="/"
  alternates={alternates}
>
  <Header ctaHref="/pl/kontakt" ctaLabel="Wyceń projekt" />

  <main>
    <HeroSection />
    <FeaturesSection />
    <ProjectsSection />
    <AboutSection />

    <!-- 🔥 NOWA SEKCJA SEO + 360 -->
    <section class="section-sm">
      <div class="container" style="text-align:center;">
        <h2>Stół z żywicy na zamówienie</h2>
        <p class="muted" style="max-width:600px;margin:auto;">
          Tworzę unikalne stoły dopasowane do Twojego wnętrza. Każdy projekt powstaje ręcznie z drewna i żywicy epoksydowej.
        </p>

        <!-- 🔥 360 VIEW -->
        <div id="table360" style="margin-top:1.5rem;">
          <img 
            id="frame360"
            src="/images/360/frame_0_0.png"
            style="width:100%;max-width:500px;border-radius:12px;"
          />
        </div>

        <a href="/pl/stol-z-zywicy-na-zamowienie" class="btn btn-primary" style="margin-top:1rem;">
          Zobacz więcej
        </a>
      </div>
    </section>

    <CTASection />
  </main>

  <Footer />

  <!-- 🔥 AUTO ROTACJA -->
  <script>
    const frames = [];
    const rows = 6;
    const cols = 6;

    for (let y = 0; y < rows; y++) {
      for (let x = 0; x < cols; x++) {
        frames.push(`/images/360/frame_${y}_${x}.png`);
      }
    }

    let index = 0;
    const img = document.getElementById("frame360");

    setInterval(() => {
      index = (index + 1) % frames.length;
      img.src = frames[index];
    }, 80);
  </script>

</MainLayout>