---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const alternates = [
  { hrefLang: 'pl', href: 'https://lucyepoxy.com/pl/kontakt' },
  { hrefLang: 'en', href: 'https://lucyepoxy.com/en/contact' },
  { hrefLang: 'de', href: 'https://lucyepoxy.com/de/kontakt' },
];
---

<MainLayout
  title="Kontakt | Lucy Epoxy Studio"
  description="Kontaktieren Sie Lucy Epoxy Studio für ein individuelles Angebot auf dem deutschen Markt."
  lang="de"
  pathname="/de/kontakt"
  alternates={alternates}
>
  <Header ctaHref="/de/kontakt" ctaLabel="E-Mail senden" />
  <main class="section">
    <div class="container" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;">
      <section class="card" style="padding:1.4rem;display:grid;gap:.7rem;">
        <p class="gold">Kontakt</p>
        <h1 style="margin-top:.2rem;">Erzählen Sie mir von Ihrem Projekt</h1>
        <p class="muted">Schreiben Sie an <a href="mailto:info@lucyepoxy.com">info@lucyepoxy.com</a>, rufen Sie mich an oder schreiben Sie per WhatsApp. Ich antworte in der Regel innerhalb von 24h.</p>
        <p>📞 <a href="tel:+48603362741">0048 603 362 741</a></p>
        <p>💬 <a href="https://wa.me/48603362741" target="_blank" rel="noopener noreferrer">WhatsApp: 0048 603 362 741</a></p>
      </section>

      <form class="card" style="padding:1.4rem;display:grid;gap:.75rem;" action="https://formsubmit.co/info@lucyepoxy.com" method="POST">
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value="https://lucyepoxy.com/de/kontakt?sent=1" />
        <label>Name <input required name="name" style="width:100%;margin-top:.3rem;padding:.7rem;border:1px solid #d8ccb7;border-radius:10px;" /></label>
        <label>E-Mail <input required type="email" name="email" style="width:100%;margin-top:.3rem;padding:.7rem;border:1px solid #d8ccb7;border-radius:10px;" /></label>
        <label>Projektdetails <textarea required name="message" rows="5" style="width:100%;margin-top:.3rem;padding:.7rem;border:1px solid #d8ccb7;border-radius:10px;"></textarea></label>
        <button type="submit" class="btn btn-primary" style="border:none;">Anfrage senden</button>
      </form>
    </div>
  </main>
  <Footer />
</MainLayout>
