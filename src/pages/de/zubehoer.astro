---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const alternates = [
  { hrefLang: 'pl', href: 'https://lucyepoxy.com/pl/dodatki' },
  { hrefLang: 'en', href: 'https://lucyepoxy.com/en/accessories' },
  { hrefLang: 'de', href: 'https://lucyepoxy.com/de/zubehoer' },
];
---

<MainLayout
  title="Zubehör | Lucy Epoxy Studio"
  description="Zubehör und Veredelungsoptionen für Epoxidharz-Tische: Gestelle, Unterbauten, Kanten und Premium-Details."
  lang="de"
  pathname="/de/zubehoer"
  alternates={alternates}
>
  <Header ctaHref="/de/kontakt" ctaLabel="Projekt anfragen" />
  <main class="section-sm">
    <div class="container">
      <p class="gold">Angebot</p>
      <h1 style="margin-top:.5rem;">Zubehör & Veredelung</h1>
      <p class="muted" style="max-width:62ch;margin-top:.7rem;">Wähle Zubehör passend zum Charakter deiner Innenräume. Für Kunden, die einen Tisch bestellen, ist das Zubehör kostenlos.</p>

      <div class="grid" style="margin-top:1.5rem;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;">
        <img src="/images/dodatek1.jpg" style="width:100%;border-radius:14px;" loading="lazy" />
        <img src="/images/dodatek2.jpg" style="width:100%;border-radius:14px;" loading="lazy" />
        <img src="/images/dodatek3.jpg" style="width:100%;border-radius:14px;" loading="lazy" />
        <img src="/images/dodatek4.jpg" style="width:100%;border-radius:14px;" loading="lazy" />
        <img src="/images/dodatek5.jpg" style="width:100%;border-radius:14px;" loading="lazy" />
        <img src="/images/dodatek6.jpg" style="width:100%;border-radius:14px;" loading="lazy" />
        <img src="/images/dodatek7.jpg" style="width:100%;border-radius:14px;" loading="lazy" />
        <img src="/images/dodatek8.jpg" style="width:100%;border-radius:14px;" loading="lazy" />
        <img src="/images/dodatek9.jpg" style="width:100%;border-radius:14px;" loading="lazy" />
      </div>
    </div>
  </main>
  <Footer />
</MainLayout>