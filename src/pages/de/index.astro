---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import HeroSection from '../../components/HeroSection.astro';
import FeaturesSection from '../../components/FeaturesSection.astro';
import ProjectsSection from '../../components/ProjectsSection.astro';
import AboutSection from '../../components/AboutSection.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';

const alternates = [
  { hrefLang: 'pl', href: 'https://lucyepoxy.com/' },
  { hrefLang: 'en', href: 'https://lucyepoxy.com/en/' },
  { hrefLang: 'de', href: 'https://lucyepoxy.com/de/' },
];
---

<MainLayout
  title="Lucy Epoxy Studio | Exklusive Epoxidharz-Tische für Deutschland"
  description="Maßgefertigte Epoxidharz-Tische mit Holz, Harz und Blumen für den deutschen Markt."
  lang="de"
  pathname="/de/"
  alternates={alternates}
>
  <Header ctaHref="/de/kontakt" ctaLabel="Projekt anfragen" />
  <main>
    <HeroSection />
    <FeaturesSection />
    <ProjectsSection />

    <!-- 🔥 NOWA SEKCJA SEO -->
    <section class="section-sm">
      <div class="container" style="text-align:center;">
        <h2>Epoxidharz Tisch nach Maß</h2>
        <p class="muted" style="max-width:600px;margin:auto;">
          Entdecken Sie individuell gefertigte Epoxidharz Tische aus Holz und Resin.
        </p>

        <a href="/de/epoxidharz-tisch-nach-mass" class="btn btn-primary" style="margin-top:1rem;">
          Mehr erfahren
        </a>
      </div>
    </section>

    <AboutSection />
    <CTASection />
  </main>
  <Footer />
</MainLayout>