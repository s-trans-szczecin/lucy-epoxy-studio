---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const alternates = [
  { hrefLang: 'pl', href: 'https://lucyepoxy.com/pl/aplikacja' },
  { hrefLang: 'en', href: 'https://lucyepoxy.com/en/mobile-app' },
  { hrefLang: 'de', href: 'https://lucyepoxy.com/de/android-app' },
];
---

<MainLayout
  title="Aplikacja mobilna | Lucy Epoxy Studio"
  description="Pobierz aplikację Lucy Epoxy Studio bezpośrednio ze strony, bez pośrednictwa Google Play."
  lang="pl"
  pathname="/pl/aplikacja"
  alternates={alternates}
>
  <Header ctaHref="/pl/kontakt" ctaLabel="Pomoc" />

  <main class="section">
    <div class="container card" style="padding:2rem;text-align:center;max-width:820px;">
      <p class="gold">Aplikacja mobilna</p>
      <h1 style="margin-top:.55rem;">Pobierz APK bezpośrednio ze strony</h1>
      <p class="muted" style="margin-top:1rem;">Aplikacja nie jest publikowana w Google Play. Pobranie odbywa się wyłącznie z oficjalnej strony Lucy Epoxy Studio.</p>
      <div style="margin-top:1.25rem;display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap;">
        <a href="/downloads/lucy-epoxy-studio.apk" class="btn btn-primary" download>Pobierz APK na Android</a>
        <a href="mailto:info@lucyepoxy.com" class="btn btn-secondary">Napisz: info@lucyepoxy.com</a>
      </div>
    </div>
  </main>

  <Footer />
</MainLayout>
