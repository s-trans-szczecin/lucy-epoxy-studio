---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<MainLayout title="Polityka prywatności | Lucy Epoxy Studio" lang="pl" pathname="/pl/polityka">
  <Header ctaHref="/pl/kontakt" ctaLabel="Wyceń projekt" />

  <main class="section-sm">
    <div class="container card" style="padding:1.5rem; line-height:1.7;">

      <h1>Polityka prywatności, cookies i regulamin</h1>

      <h2>1. Administrator danych</h2>
      <p>Administratorem danych jest Lucy Epoxy Studio.</p>

      <h2>2. Zakres danych</h2>
      <p>Przetwarzamy dane podane dobrowolnie w formularzu kontaktowym.</p>

      <h2>3. Cel przetwarzania</h2>
      <p>Odpowiedź na zapytanie, realizacja usług.</p>

      <h2>4. Cookies</h2>
      <p>Strona wykorzystuje pliki cookies w celach technicznych i analitycznych.</p>

      <h2>5. Regulamin</h2>
      <p>Korzystanie ze strony oznacza akceptację niniejszych warunków.</p>

    </div>
  </main>

  <Footer />
</MainLayout>