---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import HeroSection from '../../components/HeroSection.astro';
import FeaturesSection from '../../components/FeaturesSection.astro';
import ProjectsSection from '../../components/ProjectsSection.astro';
import AboutSection from '../../components/AboutSection.astro';
import CTASection from '../../components/CTASection.astro';
import Footer from '../../components/Footer.astro';

const alternates = [
  { hrefLang: 'pl', href: 'https://lucyepoxy.com/' },
  { hrefLang: 'en', href: 'https://lucyepoxy.com/en/' },
  { hrefLang: 'de', href: 'https://lucyepoxy.com/de/' },
];
---

<MainLayout
  title="Lucy Epoxy Studio | Premium Epoxy Resin Tables in Europe"
  description="Custom epoxy tables, countertops and interior details for clients across the EU. Elegant design, precision craftsmanship."
  lang="en"
  pathname="/en/"
  alternates={alternates}
>
  <Header ctaHref="/en/contact" ctaLabel="Get a quote" />

  <main>
    <HeroSection />
    <FeaturesSection />
    <ProjectsSection />
    <AboutSection />

    <!-- 🔥 SEO SECTION -->
    <section class="section-sm">
      <div class="container" style="text-align:center;">
        <h2>Custom Epoxy Table</h2>
        <p class="muted" style="max-width:600px;margin:auto;">
          I create handcrafted epoxy tables made from wood and resin. Each project is unique and tailored to your space.
        </p>

        <a href="/en/custom-epoxy-table" class="btn btn-primary" style="margin-top:1rem;">
          Learn more
        </a>
      </div>
    </section>

    <CTASection />
  </main>

  <Footer />
</MainLayout>