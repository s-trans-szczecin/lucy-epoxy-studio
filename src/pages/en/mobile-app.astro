---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const alternates = [
  { hrefLang: 'pl', href: 'https://lucyepoxy.com/pl/aplikacja' },
  { hrefLang: 'en', href: 'https://lucyepoxy.com/en/mobile-app' },
  { hrefLang: 'de', href: 'https://lucyepoxy.com/de/android-app' },
];
---

<MainLayout
  title="Mobile App | Lucy Epoxy Studio"
  description="Download the Lucy Epoxy Studio Android APK directly from our official website."
  lang="en"
  pathname="/en/mobile-app"
  alternates={alternates}
>
  <Header ctaHref="/en/contact" ctaLabel="Need help" />
  <main class="section">
    <div class="container card" style="padding:1.8rem;text-align:center;max-width:760px;">
      <h1>Download the mobile app</h1>
      <p class="muted" style="margin-top:.9rem;">The app is distributed directly from our official website.</p>
      <a href="/downloads/lucy-epoxy-studio.apk" class="btn btn-primary" style="margin-top:1.1rem;" download>Download APK</a>
    </div>
  </main>
  <Footer />
</MainLayout>
