---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const alternates = [
  { hrefLang: 'pl', href: 'https://lucyepoxy.com/pl/dodatki' },
  { hrefLang: 'en', href: 'https://lucyepoxy.com/en/accessories' },
  { hrefLang: 'de', href: 'https://lucyepoxy.com/de/zubehoer' },
];
---

<MainLayout
  title="Accessories | Lucy Epoxy Studio"
  description="Accessories and finishing options for epoxy resin tables and interiors: legs, bases, trims, and premium details."
  lang="en"
  pathname="/en/accessories"
  alternates={alternates}
>
  <Header ctaHref="/en/contact" ctaLabel="Get a quote" />
  <main class="section-sm">
    <div class="container">
      <p class="gold">Offer</p>
      <h1 style="margin-top:.5rem;">Accessories & finishing</h1>
      <p class="muted" style="max-width:62ch;margin-top:.7rem;">We match accessories to your space and tabletop style, from modern steel bases to elegant finishing details.</p>
      <div class="grid" style="margin-top:1.5rem;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;">
        <img src="/images/project5.jpg" alt="Epoxy table accessories" style="width:100%;border-radius:14px;" loading="lazy" />
        <img src="/images/project6.jpg" alt="Premium tabletop finishing" style="width:100%;border-radius:14px;" loading="lazy" />
        <img src="/images/project7.jpg" alt="Design accessories for epoxy projects" style="width:100%;border-radius:14px;" loading="lazy" />
      </div>
    </div>
  </main>
  <Footer />
</MainLayout>
