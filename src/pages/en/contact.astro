---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const alternates = [
  { hrefLang: 'pl', href: 'https://lucyepoxy.com/pl/kontakt' },
  { hrefLang: 'en', href: 'https://lucyepoxy.com/en/contact' },
  { hrefLang: 'de', href: 'https://lucyepoxy.com/de/kontakt' },
];
---

<MainLayout
  title="Contact | Lucy Epoxy Studio"
  description="Contact Lucy Epoxy Studio for a premium epoxy project quote in your country within the EU."
  lang="en"
  pathname="/en/contact"
  alternates={alternates}
>
  <Header ctaHref="/en/contact" ctaLabel="Write to us" />
  <main class="section">
    <div class="container" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;">
      <section class="card" style="padding:1.4rem;display:grid;gap:.7rem;">
        <p class="gold">Contact</p>
        <h1 style="margin-top:.2rem;">Tell me about your project</h1>
        <p class="muted">Send details to <a href="mailto:info@lucyepoxy.com">info@lucyepoxy.com</a>, call me or message on WhatsApp. I usually reply within 24h.</p>
        <p>📞 <a href="tel:+48603362741">0048 603 362 741</a></p>
        <p>💬 <a href="https://wa.me/48603362741" target="_blank" rel="noopener noreferrer">WhatsApp: 0048 603 362 741</a></p>
      </section>

      <form class="card" style="padding:1.4rem;display:grid;gap:.75rem;" action="https://formsubmit.co/info@lucyepoxy.com" method="POST">
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value="https://lucyepoxy.com/en/contact?sent=1" />
        <label>Full name <input required name="name" style="width:100%;margin-top:.3rem;padding:.7rem;border:1px solid #d8ccb7;border-radius:10px;" /></label>
        <label>Email <input required type="email" name="email" style="width:100%;margin-top:.3rem;padding:.7rem;border:1px solid #d8ccb7;border-radius:10px;" /></label>
        <label>Project details <textarea required name="message" rows="5" style="width:100%;margin-top:.3rem;padding:.7rem;border:1px solid #d8ccb7;border-radius:10px;"></textarea></label>
        <button type="submit" class="btn btn-primary" style="border:none;">Send inquiry</button>
      </form>
    </div>
  </main>
  <Footer />
</MainLayout>
