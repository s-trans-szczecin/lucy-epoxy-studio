\---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import ProjectsSection from '../../components/ProjectsSection.astro';
import Footer from '../../components/Footer.astro';

const alternates = [
  { hrefLang: 'pl', href: 'https://lucyepoxy.com/pl/realizacje' },
  { hrefLang: 'en', href: 'https://lucyepoxy.com/en/projects' },
  { hrefLang: 'de', href: 'https://lucyepoxy.com/de/realisierungen' },
];
---

<MainLayout
  title="Projects | Lucy Epoxy Studio"
  description="Portfolio of handcrafted epoxy resin projects for premium residential and commercial interiors."
  lang="en"
  pathname="/en/projects"
  alternates={alternates}
>
  <Header ctaHref="/en/contact" ctaLabel="Get a quote" />
  <main class="section-sm">
    <div class="container">
      <p class="gold">Portfolio</p>
      <h1 style="margin-top:.5rem;">My projects</h1>
    </div>
    <ProjectsSection />
  </main>
  <Footer />
</MainLayout>
