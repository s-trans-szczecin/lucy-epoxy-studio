---
interface AlternateLink {
  hrefLang: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  lang?: 'pl' | 'de' | 'en';
  pathname?: string;
  ogImage?: string;
  alternates?: AlternateLink[];
}

const {
  title = 'Lucy Epoxy Studio',
  description = 'Ekskluzywne realizacje z żywicy epoksydowej — stoły river table, blaty i zabudowy premium.',
  lang = 'pl',
  pathname = '/',
  ogImage = '/images/hero-table.jpg',
  alternates = [],
} = Astro.props as Props;

const siteUrl = 'https://lucyepoxy.com';
const canonical = new URL(pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Lucy Epoxy Studio" />
    <meta name="robots" content="index,follow" />
    <title>{title}</title>

    <link rel="canonical" href={canonical} />
    {alternates.map((item) => <link rel="alternate" hreflang={item.hrefLang} href={item.href} />)}
    <link rel="alternate" hreflang="x-default" href="https://lucyepoxy.com/" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lucy Epoxy Studio" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --bg: #f7f3ee;
        --text: #171717;
        --muted: #5f5f5f;
        --gold: #c6a86a;
        --line: #e4dccf;
        --panel: #fff;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        position: relative;
        font-family: 'Inter', sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.65;
        overflow-x: hidden;
      }

      body::before {
        content: '';
        position: fixed;
        top: -22%;
        left: -38%;
        width: 58%;
        height: 145%;
        pointer-events: none;
        z-index: 4;
        background: linear-gradient(112deg, transparent 0%, rgba(255, 247, 218, 0.30) 45%, rgba(255, 238, 183, 0.62) 50%, rgba(255, 247, 218, 0.26) 55%, transparent 100%);
        filter: blur(12px);
        mix-blend-mode: soft-light;
        animation: lighthouse-beam 14s ease-in-out infinite;
      }

      a { color: inherit; text-decoration: none; }
      .container { width: min(1180px, 92%); margin-inline: auto; position: relative; z-index: 2; }
      .section { padding: 5rem 0; }
      .section-sm { padding: 3.25rem 0; }
      .muted { color: var(--muted); }
      .gold { color: var(--gold); letter-spacing: 0.18em; text-transform: uppercase; font-size: 0.78rem; }

      h1, h2, h3 {
        font-family: 'Playfair Display', serif;
        font-weight: 600;
        line-height: 1.14;
        letter-spacing: -0.01em;
      }
      h1 { font-size: clamp(2rem, 4.3vw, 3.95rem); }
      h2 { font-size: clamp(1.45rem, 2.5vw, 2.4rem); }

      .btn {
        position: relative;
        overflow: hidden;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0.75rem 1.35rem;
        border-radius: 7px;
        border: 1px solid transparent;
        font-size: 0.95rem;
        font-weight: 500;
        text-decoration: none;
        transition: transform .25s ease, box-shadow .25s ease, background-color .25s ease;
      }
      .btn::after {
        content: '';
        position: absolute;
        inset: -120% 40% -120% -40%;
        transform: rotate(12deg) translateX(-180%);
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.55), transparent);
        transition: transform .55s ease;
      }
      .btn:hover { transform: translateY(-2px) scale(1.01); }
      .btn:hover::after { transform: rotate(12deg) translateX(220%); }

      .btn-primary {
        background: linear-gradient(135deg, #d2b57a, var(--gold));
        color: #fff;
        box-shadow: 0 10px 24px rgba(161, 125, 57, .2);
      }
      .btn-secondary {
        background: rgba(255, 255, 255, .82);
        border-color: #ceb587;
        color: #785e2f;
      }

      .card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 12px;
      }




      .site-header-grid {
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        gap: 1rem;
        padding: .82rem 0;
      }

      .site-actions-panel {
        display: grid;
        gap: .55rem;
        justify-items: start;
      }

      .site-brand-link { display: inline-flex; align-items: center; }
      .site-nav-buttons {
        justify-self: start;
        display: flex;
        gap: .55rem;
        flex-wrap: wrap;
        font-size: .92rem;
      }
      .nav-btn {
        min-height: 38px;
        padding: .38rem .78rem;
        background: rgba(219,191,134,.28);
        border-color: #ccb27e;
        color: #6c5224;
      }
      .site-quote-btn { min-height: 42px; padding: .58rem 1rem; }

      .hero-shell {
        border: 1px solid var(--line);
        background: rgba(255,255,255,.74);
      }
      .hero-overlay { transition: .3s ease; }
      .hero-logo-wrap { background: transparent; }

      .mobile-only { display: none; }
      .desktop-only { display: block; }


      .assistant-toggle {
        position: fixed;
        right: 14px;
        bottom: 14px;
        z-index: 120;
        border: none;
        cursor: pointer;
        border-radius: 999px;
        background: linear-gradient(135deg, #d2b57a, var(--gold));
        color: #fff;
        font-weight: 600;
        padding: .62rem .92rem;
        box-shadow: 0 10px 22px rgba(100, 75, 28, .28);
      }
      .assistant-panel {
        position: fixed;
        right: 14px;
        bottom: 64px;
        width: min(92vw, 360px);
        z-index: 121;
        background: rgba(255,255,255,.97);
        border: 1px solid #dbcda9;
        border-radius: 14px;
        box-shadow: 0 18px 35px rgba(46,40,27,.20);
        padding: .9rem;
        display: none;
      }
      .assistant-panel.open { display: block; }
      .assistant-chip {
        display:inline-block; margin:.2rem .2rem 0 0; padding:.35rem .55rem; border-radius:999px;
        border:1px solid #d6c191; background:#faf6ee; cursor:pointer; font-size:.82rem;
      }
      .assistant-answer { margin-top:.6rem; font-size:.92rem; color:#3a3428; }

      .logo-magic {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        perspective: 900px;
      }
      .logo-coin {
        display: block;
        animation: logo-rotate 24s linear infinite;
        transform-origin: center center;
      }
      .logo-magic__halo {
        position: absolute;
        inset: -8px;
        border-radius: 18px;
        pointer-events: none;
        border: 1px solid rgba(206, 177, 121, 0.3);
        opacity: 0;
        transform: rotate(0deg) scale(0.98);
        animation: halo-spin 16s ease-in-out infinite;
      }
      .logo-magic__flash {
        position: absolute;
        inset: 18%;
        border-radius: 18px;
        pointer-events: none;
        opacity: 0;
        background: radial-gradient(circle, rgba(255, 249, 226, .85) 0%, rgba(252, 227, 173, .38) 36%, transparent 70%);
        filter: blur(2px);
        animation: logo-flash 12s ease-in-out infinite;
      }
      .logo-magic__halo::before {
        content: '';
        position: absolute;
        inset: -2px;
        border-radius: 18px;
        border-top: 2px solid rgba(224, 200, 152, 0.88);
        border-right: 1px solid transparent;
        filter: drop-shadow(0 0 6px rgba(220, 193, 141, 0.42));
      }

      @keyframes logo-rotate {
        0% { transform: rotateY(0deg); }
        50% { transform: rotateY(180deg); filter: brightness(1.1) drop-shadow(0 0 10px rgba(228, 195, 126, .28)); }
        100% { transform: rotateY(360deg); }
      }

      @keyframes logo-flash {
        0%, 45%, 100% { opacity: 0; }
        50% { opacity: .88; }
        56% { opacity: .08; }
      }

      @keyframes halo-spin {
        0%, 52%, 100% { opacity: 0; transform: rotate(0deg) scale(0.98); }
        58% { opacity: .25; }
        70% { opacity: .75; transform: rotate(190deg) scale(1.02); }
        82% { opacity: .2; transform: rotate(360deg) scale(1.01); }
      }

      @keyframes lighthouse-beam {
        0%, 100% { transform: translateX(-28vw) rotate(-7deg); opacity: 0; }
        10% { opacity: .16; }
        36% { transform: translateX(155vw) rotate(-5deg); opacity: .34; }
        58% { opacity: .06; }
        76% { transform: translateX(-24vw) rotate(-6deg); opacity: 0; }
      }

      @media (max-width: 760px) {
        body::before { width: 90%; left: -56%; opacity: .65; }
        .section { padding: 3.5rem 0; }
        .section-sm { padding: 2.6rem 0; }
        header {
          background: transparent !important;
          border-bottom: none !important;
          backdrop-filter: none !important;
        }

        .site-header-grid {
          grid-template-columns: 1fr;
          gap: .55rem;
          align-items: start;
        }

        .site-actions-panel {
          grid-row: 1;
          background: rgba(247,243,238,.5);
          border: 1px solid rgba(211, 194, 157, .5);
          backdrop-filter: blur(8px);
          border-radius: 12px;
          padding: .5rem;
          width: fit-content;
          max-width: 100%;
        }

        .site-nav-buttons {
          justify-self: start;
          gap: .42rem;
        }

        .site-quote-btn {
          justify-self: start;
          min-height: 36px;
          padding: .42rem .62rem;
          font-size: .82rem;
        }

        .site-brand-link {
          display: none;
        }

        .nav-btn {
          min-height: 34px;
          padding: .28rem .56rem;
          font-size: .8rem;
        }

        .mobile-only { display: block; }
        .desktop-only { display: none; }

        .hero-shell {
          background: rgba(255,255,255,.5);
          border-color: rgba(202, 187, 157, .45);
        }

        .hero-overlay {
          background: linear-gradient(90deg,rgba(247,243,238,.55) 0%, rgba(247,243,238,.50) 45%, rgba(247,243,238,.28) 75%, rgba(247,243,238,.18) 100%) !important;
        }

        .hero-logo-wrap {
          background: transparent !important;
          box-shadow: none !important;
        }
      }
    </style>
  </head>
  <body>
    <slot />
	<!-- COOKIE BANNER -->
<div id="cookie-banner" style="position:fixed;bottom:0;width:100%;background:#222;color:#fff;padding:1rem;text-align:center;z-index:999;">
  Ta strona używa cookies.
  <button id="cookie-ok" style="margin-left:1rem;">OK</button>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const banner = document.getElementById('cookie-banner');
    const btn = document.getElementById('cookie-ok');

    if (localStorage.getItem('cookiesAccepted')) {
      banner.style.display = 'none';
    }

    btn.addEventListener('click', function () {
      localStorage.setItem('cookiesAccepted', 'true');
      banner.style.display = 'none';
    });
  });
</script>
  </body>
</html>
