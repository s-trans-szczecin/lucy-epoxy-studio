---
const pathname = Astro.url.pathname;
const lang = pathname.startsWith('/en') ? 'en' : pathname.startsWith('/de') ? 'de' : 'pl';

// ✅ SPRAWDZAMY CZY TO STRONA GŁÓWNA
const isHome =
  pathname === '/' ||
  pathname === '/en/' ||
  pathname === '/de/';

// ✅ TEKSTY
const copy = {
  pl: { label: 'Projekty', title: 'Zobacz moje projekty', cta: 'Zobacz więcej projektów', href: '/pl/realizacje' },
  en: { label: 'Projects', title: 'See my projects', cta: 'See more projects', href: '/en/projects' },
  de: { label: 'Projekte', title: 'Sehen Sie meine Projekte', cta: 'Mehr Projekte ansehen', href: '/de/realisierungen' },
} as const;

const t = copy[lang];

// ✅ WSZYSTKIE PROJEKTY
const allProjects = [
  '/images/project1.jpg',
  '/images/project2.jpg',
  '/images/project3.jpg',
  '/images/project4.jpg',
  '/images/project5.jpg',
  '/images/project6.jpg',
  '/images/project7.jpg',
];

// ✅ NA HOME TYLKO 3 WYBRANE
const projects = isHome
  ? [
      '/images/project1.jpg',
      '/images/project3.jpg',
      '/images/project5.jpg',
    ]
  : allProjects;
---

<section class="section-sm" style="background:#f8f4ee;">
  <div class="container" style="text-align:center;">
    <p class="gold">{t.label}</p>
    <h2 style="margin-top:.5rem;">{t.title}</h2>

    <div style="margin-top:1.2rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:.8rem;">
      {projects.map((img, i) => (
        <img 
          src={img} 
          alt={`Project ${i + 1}`} 
          class="card" 
          style="width:100%;aspect-ratio:1/1;object-fit:cover;" 
        />
      ))}
    </div>

    <!-- ✅ PRZYCISK TYLKO NA STRONIE GŁÓWNEJ -->
    {isHome && (
      <a href={t.href} class="btn btn-secondary" style="margin-top:1.15rem;">
        {t.cta}
      </a>
    )}
  </div>
</section>