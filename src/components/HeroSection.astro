---
const pathname = Astro.url.pathname;
const lang = pathname.startsWith('/en') ? 'en' : pathname.startsWith('/de') ? 'de' : 'pl';

const copy = {
  pl: { label: 'Projekty', title: 'Zobacz moje projekty', cta: 'Zobacz więcej projektów', href: '/pl/realizacje' },
  en: { label: 'Projects', title: 'See my projects', cta: 'See more projects', href: '/en/projects' },
  de: { label: 'Projekte', title: 'Sehen Sie meine Projekte', cta: 'Mehr Projekte ansehen', href: '/de/realisierungen' },
} as const;
const t = copy[lang];
---
<section class="section-sm" style="background:#f8f4ee;">
  <div class="container" style="text-align:center;">
    <p class="gold">{t.label}</p>
    <h2 style="margin-top:.5rem;">{t.title}</h2>
    <div style="margin-top:1.2rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:.8rem;">
      <img src="/images/project1.jpg" alt="Project 1" class="card" style="width:100%;aspect-ratio:1/1;object-fit:cover;" />
      <img src="/images/project2.jpg" alt="Project 2" class="card" style="width:100%;aspect-ratio:1/1;object-fit:cover;" />
      <img src="/images/project3.jpg" alt="Project 3" class="card" style="width:100%;aspect-ratio:1/1;object-fit:cover;" />
      <img src="/images/project4.jpg" alt="Project 4" class="card" style="width:100%;aspect-ratio:1/1;object-fit:cover;" />
      <img src="/images/project5.jpg" alt="Project 5" class="card" style="width:100%;aspect-ratio:1/1;object-fit:cover;" />
      <img src="/images/project6.jpg" alt="Project 6" class="card" style="width:100%;aspect-ratio:1/1;object-fit:cover;" />
      <img src="/images/project7.jpg" alt="Project 7" class="card" style="width:100%;aspect-ratio:1/1;object-fit:cover;" />
    </div>
    <a href={t.href} class="btn btn-secondary" style="margin-top:1.15rem;">{t.cta}</a>
  </div>
</section>
