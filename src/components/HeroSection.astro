---
const pathname = Astro.url.pathname;
const lang = pathname.startsWith('/en') ? 'en' : pathname.startsWith('/de') ? 'de' : 'pl';

const copy = {
  pl: {
    alt: 'Ekskluzywny stół epoxy',
    heading: 'Pasja, która zamienia naturę w luksus.',
    body: 'Tworzę unikatowe stoły z drewna, żywicy i kwiatów dla osób, które cenią rzeczy wyjątkowe i niepowtarzalne.',
    sub: 'Jeden egzemplarz.<br>Jedna historia.',
    projects: 'Zobacz projekty',
    quote: 'Zapytaj o wycenę',
    projectsHref: '/pl/realizacje',
    quoteHref: '/pl/kontakt',
  },
  en: {
    alt: 'Exclusive epoxy table',
    heading: 'A passion that turns nature into luxury.',
    body: 'I create one-of-a-kind tables from wood, resin, and flowers for people who value truly unique pieces.',
    sub: 'One piece.<br>One story.',
    projects: 'See projects',
    quote: 'Request a quote',
    projectsHref: '/en/projects',
    quoteHref: '/en/contact',
  },
  de: {
    alt: 'Exklusiver Epoxidharz-Tisch',
    heading: 'Leidenschaft, die Natur in Luxus verwandelt.',
    body: 'Ich fertige einzigartige Tische aus Holz, Harz und Blumen für Menschen, die das Besondere schätzen.',
    sub: 'Ein Exemplar.<br>Eine Geschichte.',
    projects: 'Projekte ansehen',
    quote: 'Angebot anfragen',
    projectsHref: '/de/realisierungen',
    quoteHref: '/de/kontakt',
  },
} as const;

const t = copy[lang];
---

<section class="section" style="padding-top:1.6rem;">
  <div class="container hero-shell" style="overflow:hidden;position:relative;border-radius:0;min-height:560px;display:grid;grid-template-columns:1fr;">
    <img src="/images/hero-table.jpg" alt={t.alt} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
    
    <!-- LEPSZY KONTRAST -->
    <div class="hero-overlay" style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(247,243,238,.97) 0%, rgba(247,243,238,.9) 45%, rgba(247,243,238,.35) 75%, rgba(247,243,238,.15) 100%);"></div>

    <div style="position:relative;z-index:1;display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;align-items:center;padding:3rem 2.5rem;">
      <div>
        <h1 style="max-width:16ch;">{t.heading}</h1>
        <p class="muted" style="margin-top:1rem;max-width:56ch;">{t.body}</p>

        <!-- KLUCZOWA ZMIANA -->
        <p 
          class="muted hero-sub"
          style="margin-top:.55rem;font-weight:600;"
          set:html={t.sub}>
        </p>

        <div style="margin-top:1.35rem;display:flex;gap:.75rem;flex-wrap:wrap;">
          <a href={t.projectsHref} class="btn btn-primary">{t.projects}</a>
          <a href={t.quoteHref} class="btn btn-secondary">{t.quote}</a>
        </div>
      </div>

      <div class="hero-logo-wrap" style="justify-self:center;text-align:center;">
        <span class="logo-magic" style="width:min(430px,85vw);">
          <img src="/images/logo-lec.png" alt="Logo Lucy Epoxy Studio" class="logo-coin" style="width:100%;height:auto;box-shadow:0 18px 40px rgba(30,30,30,.15);" />
          <span class="logo-magic__halo" style="inset:-10px;"></span>
          <span class="logo-magic__flash"></span>
        </span>
      </div>
    </div>
  </div>
</section>

<style>
.hero-sub {
  color: #1a1a1a;
  text-shadow: 0 1px 2px rgba(255,255,255,0.7);
}

@media (max-width: 768px) {
  .hero-sub {
    color: #000;
    text-shadow: 0 2px 6px rgba(255,255,255,0.95);
  }
}
</style>