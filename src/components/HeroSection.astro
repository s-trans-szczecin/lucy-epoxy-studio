    <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(247,243,238,.96) 0%, rgba(247,243,238,.83) 42%, rgba(247,243,238,.18) 75%, rgba(247,243,238,.1) 100%);"></div>

    <div style="position:relative;z-index:1;display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1rem;align-items:center;padding:3rem 2.5rem;">
