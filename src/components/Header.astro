---
interface Props {
  ctaHref?: string;
  ctaLabel?: string;
}

const pathname = Astro.url.pathname;
const lang = pathname.startsWith('/en') ? 'en' : pathname.startsWith('/de') ? 'de' : 'pl';

const navMap = {
  pl: {
    home: '/',
    projects: '/pl/realizacje',
    contact: '/pl/kontakt',
    app: '/pl/aplikacja',
    extras: '/pl/dodatki',
    about: '/pl/o-mnie',
    labels: { home: 'Home', projects: 'Projekty', about: 'O mnie', contact: 'Kontakt', app: 'Aplikacja', extras: 'Dodatki', cta: 'Zapytaj o wycenę' },
  },
  en: {
    home: '/en/',
    projects: '/en/projects',
    contact: '/en/contact',
    app: '/en/mobile-app',
    extras: '/en/accessories',
    about: '/en/about',
    labels: { 
      home: 'Home', 
      projects: 'Projects', 
      about: 'About me', 
      contact: 'Contact', 
      app: 'Mobile app', 
      extras: 'Accessories', 
      cta: 'Get a quote' 
    },
  },
  de: {
    home: '/de/',
    projects: '/de/realisierungen',
    contact: '/de/kontakt',
    app: '/de/android-app',
    extras: '/de/zubehoer',
    about: '/de/ueber-mich',
    labels: { home: 'Home', projects: 'Projekte', about: 'Über mich', contact: 'Kontakt', app: 'Android App', extras: 'Zubehör', cta: 'Angebot' },
  },
} as const;

const current = navMap[lang];
const { ctaHref = current.contact, ctaLabel = current.labels.cta } = Astro.props as Props;
---

<header style="position:sticky;top:0;z-index:60;background:rgba(247,243,238,.92);border-bottom:1px solid #e6ddce;backdrop-filter:blur(7px);">
  <div class="container site-header-grid">
    <div class="site-actions-panel">
      <nav class="site-nav-buttons">
        <a href={current.home} class="btn btn-secondary nav-btn">{current.labels.home}</a>
        <a href={current.projects} class="btn btn-secondary nav-btn">{current.labels.projects}</a>
        <a href={current.extras} class="btn btn-secondary nav-btn">{current.labels.extras}</a>
        <a href={current.about} class="btn btn-secondary nav-btn">{current.labels.about}</a>
        <a href={current.contact} class="btn btn-secondary nav-btn">{current.labels.contact}</a>
        <a href={current.app} class="btn btn-secondary nav-btn">{current.labels.app}</a>
        <a href="/" class="btn btn-secondary nav-btn">PL</a>
        <a href="/en/" class="btn btn-secondary nav-btn">EN</a>
        <a href="/de/" class="btn btn-secondary nav-btn">DE</a>
	    <a class="nav-btn" href="/pl/polityka">Polityka</a> 
<a class="nav-btn" href="/pl/bezpieczenstwo">Bezpieczeństwo</a> 
<a class="nav-btn" href="/en/privacy-policy">Policy</a> 
<a class="nav-btn" href="/en/product-safety">Safety</a> 
<a class="nav-btn" href="/de/datenschutz">Politik</a> 
<a class="nav-btn" href="/de/produktsicherheit">Sicherheit</a>
      </nav>
      <a href={ctaHref} class="btn btn-primary site-quote-btn">{ctaLabel}</a>
    </div>

    <a href={current.home} class="site-brand-link">
      <span class="logo-magic" style="width:148px;max-width:42vw;">
        <img src="/images/logo-lec.png" alt="Lucy Epoxy Studio logo" class="logo-coin" style="width:100%;height:auto;" />
        <span class="logo-magic__halo"></span>
        <span class="logo-magic__flash"></span>
      </span>
    </a>
  </div>
</header>