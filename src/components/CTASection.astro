---
const pathname = Astro.url.pathname;
const lang = pathname.startsWith('/en') ? 'en' : pathname.startsWith('/de') ? 'de' : 'pl';

const copy = {
  pl: { 
    title: 'Nie ma Twojego projektu? Masz własny pomysł? Zaprojektujmy wspólnie coś wyjątkowego', 
    cta: 'Zapytaj o wycenę', 
    href: '/pl/kontakt' 
  },
  en: { 
    title: "Don't see your project? Have your own idea? Let's design something unique together", 
    cta: 'Request a quote', 
    href: '/en/contact' 
  },
  de: { 
    title: 'Ist Ihr Projekt nicht dabei? Haben Sie eine eigene Idee? Lassen Sie uns gemeinsam etwas Einzigartiges entwerfen', 
    cta: 'Angebot anfragen', 
    href: '/de/kontakt' 
  },
} as const;

const t = copy[lang];
---

<section class="section-sm" style="padding-top:1rem;">
  <div class="container card" style="background:linear-gradient(180deg,#fbf7f1,#f4ede2);padding:1.6rem;text-align:center;">
    <h3 style="font-size:clamp(1.5rem,3vw,2rem);">{t.title}</h3>
    <a href={t.href} class="btn btn-primary" style="margin-top:.95rem;">{t.cta}</a>
  </div>
</section>